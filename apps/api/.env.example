# Application
APP_NAME=YAVA API
APP_ENV=development
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Jakarta
PORT=:8080

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=yava
DB_PASSWORD=yava_secret
DB_DATABASE=yava_dev
DB_SSLMODE=disable

# Auth / JWT
JWT_KEY=your-super-secret-jwt-key
JWT_TOKEN_EXPIRY=24h
JWT_REFRESH_TOKEN_EXPIRY=168h
AES_KEY=your-32-character-aes-key-here!!

# WhatsApp — Twilio (digunakan untuk OTP reset password)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# WhatsApp — Meta Business Cloud API (alternatif Twilio)
WHATSAPP_API_TOKEN=your_meta_api_token
WHATSAPP_PHONE_ID=your_phone_number_id
