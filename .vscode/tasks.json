{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start FE",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/apps/web" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev-servers",
        "panel": "dedicated",
        "reveal": "always",
        "close": false
      }
    },
    {
      "label": "Start BE",
      "type": "shell",
      "command": "air",
      "options": { "cwd": "${workspaceFolder}/apps/api" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "group": "dev-servers",
        "panel": "dedicated",
        "reveal": "always",
        "close": false
      }
    },
    {
      "label": "Start All",
      "dependsOn": ["Start FE", "Start BE"],
      "dependsOrder": "parallel",
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": []
    }
  ]
}
